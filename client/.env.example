# EmailJS (Account → API keys → Public Key)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your inbox — sent as {{to_email}} so the template “To” field is never empty
VITE_CONTACT_EMAIL=you@gmail.com

# Defaults match your EmailJS dashboard (override if you create new ones)
VITE_EMAILJS_SERVICE_ID=service_0reoan9
VITE_EMAILJS_TEMPLATE_ID=template_qguj85h
